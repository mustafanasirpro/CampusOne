# Copy this file to .env, then replace every development credential.
# Maven activates this profile automatically for spring-boot:run. Keep the
# setting for IDE launches and direct local JAR execution.
SPRING_PROFILES_ACTIVE=local
DB_URL=jdbc:postgresql://localhost:5432/campusone
DB_USERNAME=campusone
DB_PASSWORD=replace-with-a-local-password
# Production may override FLYWAY_URL, FLYWAY_USERNAME, and FLYWAY_PASSWORD
# with a separate migration role. Local development falls back to DB_*.
# Generate a unique standard Base64 secret for every environment.
JWT_SECRET=replace-with-generated-standard-base64-secret
JWT_ISSUER=campusone-backend
JWT_AUDIENCE=campusone-api
JWT_ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=7
# Use true behind HTTPS in production. Local HTTP development requires false.
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAME_SITE=Strict
REFRESH_TOKEN_CLEANUP_INTERVAL=24h
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCK_MINUTES=15
PASSWORD_RESET_TOKEN_TTL_MINUTES=30
APP_FRONTEND_URL=http://localhost:5173
# Set MAIL_ENABLED=true with real SMTP values in production to send reset
# links. Leave disabled locally unless you run a mail catcher.
MAIL_ENABLED=false
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=CampusOne <no-reply@campusone.dev>
MAIL_SMTP_AUTH=false
MAIL_SMTP_STARTTLS_ENABLE=false
# Optional locally because the local profile safely defaults to this exact
# origin. Production must explicitly set its own comma-separated origins.
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# API documentation is enabled by default; set false where it should be hidden.
OPENAPI_ENABLED=true
# Real note uploads are disabled until all R2 values below are configured.
STORAGE_PROVIDER=disabled
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_REGION=auto
# Optional public bucket/custom-domain base URL. Leave blank for private
# short-lived presigned download URLs.
R2_PUBLIC_BASE_URL=
MAX_UPLOAD_SIZE_MB=25
MARKETPLACE_MAX_IMAGES_PER_LISTING=5
MARKETPLACE_MAX_IMAGE_SIZE_MB=5
ADMIN_MAX_UPLOADS_PER_DAY=200
ADMIN_MAX_STORAGE_MB_PER_MONTH=5000
GLOBAL_UPLOAD_STORAGE_CAP_MB=8192
# Optional comma-separated fallback for note-management and approval admins.
# Prefer active ADMIN assignments in the moderators table.
ADMIN_UPLOAD_EMAILS=
STORAGE_DOWNLOAD_URL_TTL=10m
